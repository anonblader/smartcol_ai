# ============================================================================
# SmartCol AI Backend - Environment Configuration
# ============================================================================

# Node Environment
NODE_ENV=development  # development | production | test
PORT=3001

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=smartcol
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here

# Connection pool settings (optional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# CACHE (Redis)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty for local development
REDIS_DB=0

# Redis TTL settings (in seconds)
REDIS_TOKEN_TTL=3600        # 1 hour
REDIS_CACHE_TTL=900         # 15 minutes
REDIS_SESSION_TTL=86400     # 24 hours

# ============================================================================
# MICROSOFT AZURE AD (OAuth 2.0)
# ============================================================================

# Azure AD App Registration
# Get these from: https://portal.azure.com -> App registrations
AZURE_AD_CLIENT_ID=your_client_id_here
AZURE_AD_CLIENT_SECRET=your_client_secret_here
AZURE_AD_TENANT_ID=your_tenant_id_here

# OAuth Redirect URI
# Must match exactly what's configured in Azure AD
AZURE_AD_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Microsoft Graph API
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0

# Required OAuth Scopes (space-separated)
OAUTH_SCOPES=User.Read Calendars.Read Calendars.Read.Shared MailboxSettings.Read offline_access

# ============================================================================
# AZURE KEY VAULT (Production only)
# ============================================================================

# For production: Use Azure Key Vault for secrets
AZURE_KEY_VAULT_NAME=smartcol-ai-kv
AZURE_KEY_VAULT_URL=https://smartcol-ai-kv.vault.azure.net/

# Token encryption key (auto-fetched from Key Vault in production)
# For local dev: Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your_32_byte_base64_key_here

# ============================================================================
# SESSION & SECURITY
# ============================================================================

# Session secret (Generate with: openssl rand -base64 32)
SESSION_SECRET=your_random_session_secret_here

# JWT settings (if using JWT instead of sessions)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d  # 7 days

# CORS settings
CORS_ORIGIN=http://localhost:3000  # Frontend URL
CORS_CREDENTIALS=true

# Security headers
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

# ============================================================================
# AI CLASSIFICATION SERVICE
# ============================================================================

# Python FastAPI service URL
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=10000  # 10 seconds

# Classification confidence threshold
MIN_CONFIDENCE_THRESHOLD=0.5  # Flag for manual review if below

# ============================================================================
# BACKGROUND JOBS (Bull Queue)
# ============================================================================

# Calendar sync interval (in minutes)
SYNC_INTERVAL_MINUTES=15

# Job retry settings
JOB_MAX_RETRIES=3
JOB_BACKOFF_DELAY=60000  # 1 minute

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error | warn | info | debug | verbose
LOG_LEVEL=info

# Log format: json | simple
LOG_FORMAT=json

# Log file paths (leave empty to disable file logging)
LOG_FILE_ERROR=./logs/error.log
LOG_FILE_COMBINED=./logs/combined.log

# ============================================================================
# MONITORING (Azure Application Insights)
# ============================================================================

# Application Insights connection string (production)
APPINSIGHTS_INSTRUMENTATIONKEY=your_instrumentation_key_here
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your_key_here;IngestionEndpoint=https://...

# Enable/disable monitoring
ENABLE_APPINSIGHTS=false  # Set to true in production

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# Email (SendGrid, AWS SES, or SMTP)
EMAIL_PROVIDER=sendgrid  # sendgrid | ses | smtp
EMAIL_FROM=noreply@smartcol.ai
EMAIL_FROM_NAME=SmartCol AI

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here

# SMTP (alternative)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Push notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=your_fcm_server_key_here
FCM_SENDER_ID=your_sender_id_here

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_RISK_DETECTION=true
ENABLE_OFFDAY_RECOMMENDATIONS=true
ENABLE_WEEKLY_SUMMARIES=true
ENABLE_REAL_TIME_NOTIFICATIONS=true

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable detailed error messages (disable in production)
SHOW_ERROR_STACK=true

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Database query logging
ENABLE_QUERY_LOGGING=false

# Disable SSL for local PostgreSQL
DATABASE_SSL=false

# ============================================================================
# TESTING
# ============================================================================

# Test database (for running tests)
TEST_DATABASE_NAME=smartcol_test
TEST_DATABASE_USER=postgres
TEST_DATABASE_PASSWORD=test_password

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit this file with real credentials
# 2. Copy this file to .env and fill in your values
# 3. The .env file is in .gitignore and should never be committed
# 4. For production, use Azure Key Vault or similar secret management
# 5. Rotate secrets regularly (every 90 days minimum)
# 6. Use strong passwords (20+ characters, random)
# 7. Enable MFA for all Azure accounts

# Generate secure random values:
# openssl rand -base64 32  # For secrets/keys
# uuidgen                  # For IDs
