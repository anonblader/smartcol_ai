NODE_ENV=development
PORT=3001

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=smartcol
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password_here

REDIS_HOST=localhost
REDIS_PORT=6379

AZURE_AD_CLIENT_ID=your_azure_client_id_here
AZURE_AD_CLIENT_SECRET=your_azure_client_secret_here
AZURE_AD_TENANT_ID=your_azure_tenant_id_here
AZURE_AD_REDIRECT_URI=http://localhost:3001/api/auth/callback
OAUTH_SCOPES=User.Read Calendars.Read Calendars.Read.Shared MailboxSettings.Read offline_access

AZURE_KEY_VAULT_NAME=
SESSION_SECRET=generate_a_random_secret_here
TOKEN_ENCRYPTION_KEY=placeholder_key_for_dev_only

AI_SERVICE_URL=http://localhost:8000

# Email (SMTP) — leave blank to use console-log mode
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=SmartCol AI

# Comma-separated admin emails (wrap in quotes if emails contain # characters)
ADMIN_EMAILS="your_admin_email@example.com"

# Frontend URL (where normal users are redirected after login)
FRONTEND_URL=http://localhost:3000
